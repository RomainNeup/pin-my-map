# MongoDB connection string
MONGODB_URI=mongodb://localhost/pin-my-map

# JWT signing secret (change in production)
JWT_SECRET=change-me

# Comma-separated list of CORS-allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to "development" to expose Swagger UI at /api
NODE_ENV=development

# Google Places API (New) key for place enrichment.
# When unset, enrichment is silently skipped — place creation still works.
GOOGLE_PLACES_API_KEY=
