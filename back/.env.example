# MongoDB connection string
MONGODB_URI=mongodb://localhost/pin-my-map

# JWT signing secret (change in production)
JWT_SECRET=change-me

# Comma-separated list of CORS-allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to "development" to expose Swagger UI at /api
NODE_ENV=development

# Google Places API (New) key for place enrichment.
# When unset, enrichment is silently skipped — place creation still works.
GOOGLE_PLACES_API_KEY=

# SMTP settings for outgoing email (forgot-password flow, future invite emails).
# When SMTP_HOST is unset, emails are logged to stdout at INFO level instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@pin-my-map.local

# Public frontend URL used when building reset-password links.
APP_URL=http://localhost:5173

# OAuth: OIDC client IDs. When unset, the matching /auth/oauth/* endpoint
# returns 503 "OAuth provider not configured".
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=

# Bootstrap default registration mode for new sign-ups.
# Runtime value lives in AppConfig and is editable by admins via /config.
# - open              : create active user (default)
# - approval-required : create with status=pending; admin must activate
# - invite-only       : block new account creation (existing users still log in)
REGISTRATION_MODE=open
